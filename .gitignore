# --------------------------------------------------------------
# DATA — needed for deployment (dashboard reads these CSVs)
# Only exclude truly raw/huge intermediate files, keep final outputs
# --------------------------------------------------------------
data/interim/
# (data/raw/, data/processed/, data/*.csv are KEPT for deployment)

# --------------------------------------------------------------
# MODELS — keep the trained model needed by the API
# --------------------------------------------------------------
models/tuned/
models/experiments/
# (models/saved/best_model.pkl is KEPT for /predict endpoint)

# Logs (large, regenerated on each run)
outputs/logs/
data/outputs/logs/

# Database (regenerate locally, don't ship to prod)
database/*.db

